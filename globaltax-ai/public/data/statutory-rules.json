      "title": "Provident Fund — EPF & EPS",
      "authority": "Employees' Provident Fund Organisation (EPFO)",
      "act_old": "EPF & MP Act 1952; EPF Scheme 1952",
      "act_new": "Code on Social Security 2020 Ch III",
      "applicability": "Establishments with ≥ 20 employees (EPFO notified establishments also at 10+).",
      "rates": [
        { "head": "Employee contribution",      "rate": "12% of wages",  "note": "Wages = basic + DA + retaining allowance" },
        { "head": "Employer contribution",      "rate": "12% of wages",  "note": "Split into EPS 8.33% (capped at ₹1,250/mo) + EPF 3.67%" },
        { "head": "EDLI",                        "rate": "0.5% of wages", "note": "Life insurance, employer-only, ceiling ₹15k" },
        { "head": "Admin charges",               "rate": "0.5% of wages", "note": "Employer-only, minimum ₹75/month" }
      ],
      "ceilings": [
        { "label": "Statutory wage ceiling",     "value": 15000, "currency": "₹", "per": "month", "ref": "EPF Scheme Para 26A" },
        { "label": "EPS pension cap (employer)", "value": 1250,  "currency": "₹", "per": "month" }
      ],
      "deadlines": [
        { "task": "ECR upload + contribution payment", "date": "15th of following month" },
        { "task": "Annual return Form 3A/6A",           "date": "25 April" }
      ],
      "penalties": "Damages 5–25% u/s 14B + simple interest 12% p.a. u/s 7Q"
    },
